async function generateInteractive(type, options) {
  const { createInterface } = require('readline')
  const rl = createInterface({
    input: process.stdin,
    output: process.stdout
  })
  
  try {
    log.info('Ultra-interactive generation mode')
    log.info('Type "help" for commands or "done" to finish')
    
    let currentCode = ''
    let previewServer = null
    let aiAssistant = null
    
    while (true) {
      const input = await new Promise(resolve => {
        rl.question('> ', resolve)
      })
      
      if (input === 'done') break
      if (input === 'help') {
        log.info('Available commands:')
        log.info('  help - Show this help')
        log.info('  preview - Start live preview')
        log.info('  ai - Enable AI assistant')
        log.info('  save - Save current code')
        log.info('  analyze - Analyze current code')
        log.info('  optimize - Optimize current code')
        log.info('  done - Finish and save')
        continue
      }
      
      if (input === 'preview') {
        if (!previewServer) {
          previewServer = await startUltraPreviewServer(currentCode)
          log.info('Ultra preview server started at http://localhost:3001')
        }
        continue
      }
      
      if (input === 'ai') {
        if (!aiAssistant) {
          aiAssistant = await startAIAssistant()
          log.info('AI assistant enabled')
        }
        continue
      }
      
      if (input === 'save') {
        await writeUltraGeneratedCode(currentCode, options)
        log.info('Code saved!')
        continue
      }
      
      if (input === 'analyze') {
        const analysis = await analyzeCode(currentCode)
        log.info('Code analysis:', analysis)
        continue
      }
      
      if (input === 'optimize') {
        const optimized = await optimizeCode(currentCode)
        currentCode = optimized
        log.info('Code optimized!')
        continue
      }
      
      // Add input to current code
      currentCode += input + '\n'
      
      // Update preview if server is running
      if (previewServer) {
        await updateUltraPreview(previewServer, currentCode)
      }
      
      // Get AI suggestions if assistant is enabled
      if (aiAssistant) {
        const suggestions = await getAISuggestions(currentCode)
        if (suggestions.length > 0) {
          log.info('AI suggestions:')
          suggestions.forEach(suggestion => {
            log.info(`  💡 ${suggestion}`)
          })
        }
      }
    }
    
    if (previewServer) {
      await stopUltraPreviewServer(previewServer)
    }
    
    if (aiAssistant) {
      await stopAIAssistant(aiAssistant)
    }
    
    await writeUltraGeneratedCode(currentCode, options)
    log.info('Ultra-interactive generation completed!')
  } finally {
    rl.close()
  }
}

// Utility functions
async function copyUltraAdvancedTemplate(templatePath, targetPath, options) {
  const files = glob.sync('**/*', { cwd: templatePath, nodir: true })
  
  for (const file of files) {
    const src = path.join(templatePath, file)
    const dest = path.join(targetPath, file)
    
    let content = fs.readFileSync(src, 'utf8')
    
    // Replace template variables with ultra-advanced processing
    content = processUltraTemplateVariables(content, options)
    
    // Create directory if needed
    const dir = path.dirname(dest)
    if (!fs.existsSync(dir)) {
      fs.mkdirSync(dir, { recursive: true })
    }
    
    fs.writeFileSync(dest, content)
  }
}

function processUltraTemplateVariables(content, options) {
  const variables = {
    name: options.name,
    description: options.description || `${options.name} - Built with ForSure Design System`,
    version: '0.1.0',
    author: options.author || 'ForSure Team',
    license: options.license || 'MIT',
    repository: options.repository || '',
    homepage: options.homepage || '',
    bugs: options.bugs || '',
    keywords: options.keywords || ['forsure', 'design-system', 'react', 'typescript'],
    features: options.features || [],
    packageManager: options.packageManager || 'npm',
    gitProvider: options.gitProvider || 'github',
    timestamp: new Date().toISOString(),
    
    // Advanced variables
    hasTypeScript: options.features?.includes('typescript'),
    hasStorybook: options.features?.includes('storybook'),
    hasTesting: options.features?.includes('testing'),
    hasLinting: options.features?.includes('linting'),
    hasHusky: options.features?.includes('husky'),
    hasCI: options.features?.includes('github-actions'),
    hasDocker: options.features?.includes('docker'),
    hasI18n: options.features?.includes('i18n'),
    hasPWA: options.features?.includes('pwa'),
    hasServerless: options.features?.includes('serverless'),
    hasMicrofrontend: options.features?.includes('microfrontend'),
    hasMonorepo: options.features?.includes('monorepo'),
  }
  
  // Replace variables
  Object.entries(variables).forEach(([key, value]) => {
    const regex = new RegExp(`\\{\\{${key}\\}\\}`, 'g')
    content = content.replace(regex, value)
  })
  
  // Process conditional blocks
  content = content.replace(/\{\{#if\s+(\w+)\}\}([\s\S]*?)\{\{\/if\}\}/g, (match, condition, block) => {
    return variables[condition] ? block : ''
  })
  
  // Process loops
  content = content.replace(/\{\{#each\s+(\w+)\}\}([\s\S]*?)\{\{\/each\}\}/g, (match, arrayName, block) => {
    const array = variables[arrayName] || []
    return array.map(item => {
      return block.replace(/\{\{this\}\}/g, item)
    }).join('\n')
  })
  
  return content
}

