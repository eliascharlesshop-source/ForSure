const log = {
  success: (msg, meta = {}) => console.log(chalk.green('✅'), msg, meta.info ? chalk.gray(meta.info) : ''),
  error: (msg, meta = {}) => console.log(chalk.red('❌'), msg, meta.info ? chalk.gray(meta.info) : ''),
  warning: (msg, meta = {}) => console.log(chalk.yellow('⚠️'), msg, meta.info ? chalk.gray(meta.info) : ''),
