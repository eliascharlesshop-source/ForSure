# Database Configuration
# PostgreSQL Database URL for Prisma
DATABASE_URL="postgresql://username:password@localhost:5432/forsure_db?connection_limit=20&pool_timeout=20"

# Direct URL for database migrations and introspection (bypasses connection pool)
DIRECT_URL="postgresql://username:password@localhost:5432/forsure_db"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database Connection Pool Settings (Production)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_CONNECTION_TIMEOUT=10000

# Database SSL Configuration (Production)
DATABASE_SSL_MODE="require"
DATABASE_SSL_CERT_PATH=""
DATABASE_SSL_KEY_PATH=""
DATABASE_SSL_CA_PATH=""

# Redis Configuration (for caching and sessions)
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# Database Backup Configuration
BACKUP_SCHEDULE="0 2 * * *" # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET="forsure-db-backups"
BACKUP_S3_REGION="us-east-1"

# Database Monitoring
DATABASE_LOG_LEVEL="warn"
DATABASE_QUERY_TIMEOUT=30000
DATABASE_ENABLE_QUERY_LOGGING=false

# Application Configuration
NODE_ENV="development"
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# JWT Configuration
JWT_SECRET="your-jwt-secret"
JWT_EXPIRES_IN="7d"

# Email Configuration (for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760 # 10MB
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,image/gif,image/webp,application/pdf"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_BLOG=true
ENABLE_TEMPLATES=true
ENABLE_TEAMS=true
ENABLE_FILE_UPLOADS=true
ENABLE_NOTIFICATIONS=true

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=""
VERCEL_ANALYTICS_ID=""

# Logging
LOG_LEVEL="info"
LOG_FILE_PATH="./logs/app.log"
