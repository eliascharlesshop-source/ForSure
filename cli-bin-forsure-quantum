// Quantum-Enhanced logging system with real-time analytics
const log = {
  success: (msg, meta = {}) => {
    console.log(chalk.green('✨'), msg, meta.info ? chalk.gray(meta.info) : '')
    if (global.analytics) global.analytics.track('success', msg, meta)
  },
  error: (msg, meta = {}) => {
    console.log(chalk.red('💥'), msg, meta.info ? chalk.gray(meta.info) : '')
    if (global.analytics) global.analytics.track('error', msg, meta)
  },
  warning: (msg, meta = {}) => {
    console.log(chalk.yellow('⚠️'), msg, meta.info ? chalk.gray(meta.info) : '')
    if (global.analytics) global.analytics.track('warning', msg, meta)
  },
  info: (msg, meta = {}) => {
    console.log(chalk.blue('ℹ️'), msg, meta.info ? chalk.gray(meta.info) : '')
    if (global.analytics) global.analytics.track('info', msg, meta)
  },
  step: (msg, meta = {}) => {
    console.log(chalk.cyan('🔄'), msg, meta.info ? chalk.gray(meta.info) : '')
    if (global.analytics) global.analytics.track('step', msg, meta)
  },
  debug: (msg, meta = {}) => {
    if (process.env.DEBUG) console.log(chalk.gray('🐛'), msg, meta.info ? chalk.gray(meta.info) : '')
    if (global.analytics) global.analytics.track('debug', msg, meta)
  },
  benchmark: (msg, time) => {
    console.log(chalk.magenta('⚡'), msg, chalk.gray(`(${time.toFixed(2)}ms)`))
    if (global.analytics) global.analytics.track('benchmark', msg, { time })
  },
  network: (msg, status) => {
    const colors = { success: chalk.green, error: chalk.red, pending: chalk.yellow }
    console.log(colors[status]('🌐'), msg)
    if (global.analytics) global.analytics.track('network', msg, { status })
  },
  ai: (msg, confidence = 0) => {
    const confidenceColor = confidence > 80 ? chalk.green : confidence > 60 ? chalk.yellow : chalk.red
    console.log(chalk.cyan('🤖'), msg, confidenceColor(`(${confidence}% confidence)`))
    if (global.analytics) global.analytics.track('ai', msg, { confidence })
  },
  quantum: (msg, state) => {
    console.log(chalk.purple('⚛️'), msg, chalk.gray(`(${state})`))
    if (global.analytics) global.analytics.track('quantum', msg, { state })
  }
}

