{
  "name": "@forsure/quantum-cli",
  "version": "1.0.0",
  "description": "ForSure Design System CLI with advanced quantum computing capabilities",
  "main": "dist/index.js",
  "bin": {
    "forsure": "dist/cli.js",
    "forsure-quantum": "dist/quantum-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/cli.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build && npm run test && npm run lint",
    "release": "semantic-release"
  },
  "keywords": [
    "forsure",
    "design-system",
    "cli",
    "quantum-computing",
    "quantum",
    "circuit-simulation",
    "quantum-algorithms",
    "superposition",
    "entanglement",
    "quantum-optimization",
    "typescript",
    "react",
    "components",
    "ui",
    "accessibility"
  ],
  "author": "ForSure Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forsure/quantum-cli.git"
  },
  "bugs": {
    "url": "https://github.com/forsure/quantum-cli/issues"
  },
  "homepage": "https://github.com/forsure/quantum-cli#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@forsure/design-tokens": "^1.0.0",
    "@forsure/quantum-core": "^1.0.0",
    "commander": "^11.0.0",
    "inquirer": "^9.2.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.0",
    "figlet": "^1.6.0",
    "boxen": "^7.1.0",
    "fs-extra": "^11.1.0",
    "path": "^0.12.7",
    "glob": "^10.3.0",
    "semver": "^7.5.0",
    "axios": "^1.5.0",
    "ws": "^8.13.0",
    "crypto": "^1.0.1",
    "perf_hooks": "^1.0.0",
    "chokidar": "^3.5.3",
    "worker_threads": "^1.0.0",
    "cluster": "^1.0.0",
    "os": "^1.0.0",
    "util": "^1.0.0",
    "events": "^3.3.0",
    "stream": "^1.0.0",
    "zlib": "^1.0.0",
    "child_process": "^1.0.0",
    "typescript": "^5.1.0",
    "tsx": "^3.12.0",
    "complex.js": "^2.1.1",
    "mathjs": "^11.11.0",
    "uuid": "^9.0.0",
    "yaml": "^2.3.0",
    "toml": "^3.0.0",
    "json5": "^2.2.3",
    "dotenv": "^16.3.0",
    "joi": "^17.9.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@types/node": "^20.4.0",
    "@types/jest": "^29.5.0",
    "@types/inquirer": "^9.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/glob": "^8.1.0",
    "@types/semver": "^7.5.0",
    "@types/ws": "^8.5.0",
    "@types/figlet": "^1.5.0",
    "@types/lodash": "^4.14.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.6.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.44.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0",
    "semantic-release": "^21.0.0",
    "husky": "^8.0.0",
    "lint-staged": "^13.2.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "@commitlint/cli": "^17.6.0",
    "@commitlint/config-conventional": "^17.6.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "templates",
    "docs"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/*.test.ts",
      "!src/**/*.spec.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.ts"
    ]
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "eslint:recommended",
      "@typescript-eslint/recommended"
    ],
    "plugins": [
      "@typescript-eslint"
    ],
    "env": {
      "node": true,
      "es2022": true
    },
    "rules": {
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/explicit-function-return-type": "warn",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false
  },
  "release": {
    "branches": [
      "main",
      "next"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  }
}
