}

function getPageTemplate(name) {
  const pascalName = name.charAt(0).toUpperCase() + name.slice(1)
  return `import { Metadata } from 'next'
import { ${pascalName}Page } from './${name}-page'

export const metadata: Metadata = {
  title: '${pascalName}',
  description: '${pascalName} page',
}

export default function ${pascalName}Route() {
  return <${pascalName}Page />
}
`
}

function getLayoutTemplate(name) {
  const pascalName = name.charAt(0).toUpperCase() + name.slice(1)
  return `import { ReactNode } from 'react'

export interface ${pascalName}LayoutProps {
  children: ReactNode
}

export function ${pascalName}Layout({ children }: ${pascalName}LayoutProps) {
  return (
    <div className="${name}-layout">
      {children}
    </div>
  )
}
`
}

