      "  probability: ${3:0.5},",
      "  result: '${4:|0⟩}',",
      "  collapse: ${5:true},",
      "  accuracy: ${6:0.97}",
      "})"
    ],
    "description": "Perform quantum measurement"
  },
  "Quantum Gate": {
    "prefix": "gate",
    "body": [
