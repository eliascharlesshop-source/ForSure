      "  gates: [",
      "    { gate: 'H', target: 0 },",
      "    { gate: 'CNOT', control: 0, target: 1 },",
      "    { gate: 'MEASURE', target: 0 }",
      "  ],",
      "  depth: ${3:3},",
      "  fidelity: ${4:0.98},",
      "  optimization: ${5:true}",
      "})"
    ],
    "description": "Create a quantum circuit"
  },
