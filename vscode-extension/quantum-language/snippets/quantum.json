      "  maximallyEntangled: ${4:true},",
      "  fidelity: ${5:0.99},",
      "  strength: ${6:0.96}",
      "})"
    ],
    "description": "Create quantum entanglement between qubits"
  },
  "Quantum Measurement": {
    "prefix": "measurement",
    "body": [
      "performMeasurement('${1:stateId}', {",
