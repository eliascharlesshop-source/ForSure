{
  "Quantum State": {
    "prefix": "qstate",
    "body": [
      "createQuantumState(${1:qubits}, {",
      "  amplitudes: [${2:amplitudes}],",
      "  phase: ${3:phase},",
      "  coherence: ${4:coherence},",
      "  superposition: ${5:true},",
      "  entanglement: ${6:false}",
      "})"
    ],
    "description": "Create a quantum state with specified parameters"
  },
  "Superposition State": {
    "prefix": "superposition",
    "body": [
      "createSuperposition([${1:states}], {",
      "  amplitudes: [${2:amplitudes}],",
      "  normalization: ${3:1.0},",
      "  coherence: ${4:0.98},",
      "  phase: ${5:0}",
      "  probability: ${6:0.5}",
      "})"
    ],
    "description": "Create a quantum superposition state"
  },
  "Entanglement State": {
    "prefix": "entanglement",
    "body": [
      "createEntanglement([${1:qubits}], {",
