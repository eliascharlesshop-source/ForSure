  "Quantum Function": {
    "prefix": "qfunc",
    "body": [
      "function ${1:functionName}(${2:params}) {",
      "  // Quantum function implementation",
      "  const state = createQuantumState(${3:qubits});",
      "  ",
      "  // Apply quantum operations",
      "  ${4:// operations here}",
      "  ",
      "  return ${5:result};",
      "}"
    ],
    "description": "Create a quantum function"
  },
  "Quantum Class": {
    "prefix": "qclass",
    "body": [
      "class ${1:ClassName} {",
      "  constructor(${2:params}) {",
      "    this.qubits = ${3:qubits};",
      "    this.state = createQuantumState(this.qubits);",
      "    this.coherence = ${4:0.98};",
      "    this.fidelity = ${5:0.99};",
      "  }",
      "  ",
      "  ${6:// methods}",
      "}"
    ],
    "description": "Create a quantum class"
  },
  "Bell State": {
    "prefix": "bell",
    "body": [
      "// Create Bell state |Φ+⟩",
      "const bellState = createEntanglement([0, 1], {",
      "  bellState: 'Φ+',",
      "  maximallyEntangled: true,",
      "  fidelity: 0.99",
      "});"
    ],
    "description": "Create Bell state"
  },
  "GHZ State": {
    "prefix": "ghz",
    "body": [
      "// Create GHZ state",
      "const ghzState = createSuperposition(['|000⟩', '|111⟩'], {",
      "  amplitudes: [1/√2, 1/√2],",
      "  normalization: 1.0,",
      "  coherence: 0.98",
      "});"
    ],
    "description": "Create GHZ state"
  },
  "W State": {
    "prefix": "wstate",
    "body": [
