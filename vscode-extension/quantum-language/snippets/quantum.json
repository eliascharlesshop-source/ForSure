      "const wState = createSuperposition(['|100⟩', '|010⟩', '|001⟩'], {",
      "  amplitudes: [1/√3, 1/√3, 1/√3],",
      "  normalization: 1.0,",
      "  coherence: 0.97",
      "});"
    ],
    "description": "Create W state"
  },
  "Quantum Teleportation": {
    "prefix": "teleport",
    "body": [
      "// Quantum teleportation protocol",
      "function teleportQuantumState(state, aliceQubits, bobQubit) {",
      "  // Create entanglement between Alice and Bob",
      "  const entanglement = createEntanglement([aliceQubits[1], bobQubit]);",
      "  ",
      "  // Bell measurement on Alice's qubits",
      "  const measurement = performMeasurement(aliceQubits, {",
      "    basis: 'bell'",
      "    collapse: true",
      "  });",
      "  ",
      "  // Apply correction based on measurement result",
      "  if (measurement.result === '|01⟩') {",
      "    applyGate('X', bobQubit);",
      "  } else if (measurement.result === '|10⟩') {",
      "    applyGate('Z', bobQubit);",
      "  } else if (measurement.result === '|11⟩') {",
      "    applyGate('X', bobQubit);",
      "    applyGate('Z', bobQubit);",
      "  }",
      "  ",
      "  return bobQubit; // State teleported to Bob",
      "}"
    ],
    "description": "Quantum teleportation protocol"
  },
  "Quantum Fourier Transform": {
    "prefix": "qft",
    "body": [
      "// Quantum Fourier Transform",
      "function quantumFourierTransform(qubits) {",
      "  const n = qubits.length;",
      "  ",
      "  for (let i = 0; i < n; i++) {",
      "    // Apply Hadamard gate",
      "    applyGate('H', qubits[i]);",
      "    ",
      "    // Apply controlled phase gates",
      "    for (let j = i + 1; j < n; j++) {",
      "      const phase = Math.PI / Math.pow(2, j - i);",
      "      applyGate('CZ', { control: qubits[j], target: qubits[i] }, { phase });",
      "    }",
      "  }",
      "  ",
      "  // Reverse qubit order",
      "  for (let i = 0; i < n / 2; i++) {",
      "    applyGate('SWAP', { qubits: [qubits[i], qubits[n - 1 - i]] });",
      "  }",
      "}"
    ],
    "description": "Quantum Fourier Transform"
  },
  "Grover's Algorithm": {
    "prefix": "grover",
    "body": [
      "// Grover's algorithm",
      "function groversAlgorithm(oracle, n, iterations) {",
      "  // Initialize qubits",
      "  const qubits = Array(n).fill(0).map((_, i) => i);",
      "  ",
      "  // Apply Hadamard gates to create uniform superposition",
      "  qubits.forEach(q => applyGate('H', q));",
      "  ",
      "  // Grover iterations",
      "  for (let i = 0; i < iterations; i++) {",
      "    // Apply oracle",
      "    oracle(qubits);",
      "    ",
      "    // Apply diffusion operator",
      "    qubits.forEach(q => applyGate('H', q));",
      "    qubits.forEach(q => applyGate('X', q));",
      "    applyGate('CZ', { control: qubits[0], target: qubits[1] });",
      "    qubits.forEach(q => applyGate('X', q));",
      "    qubits.forEach(q => applyGate('H', q));",
      "  }",
      "  ",
      "  // Measure all qubits",
      "  return qubits.map(q => performMeasurement(q));",
      "}"
    ],
    "description": "Grover's search algorithm"
  },
  "Quantum Error Correction": {
    "prefix": "qec",
    "body": [
      "// Quantum error correction (Surface code)",
      "function surfaceCodeCorrection(dataQubits, ancillaQubits) {",
      "  // Stabilizer measurements",
      "  for (let i = 0; i < ancillaQubits.length; i++) {",
      "    const ancilla = ancillaQubits[i];",
      "    const neighbors = getNeighbors(ancilla, dataQubits);",
      "    ",
      "    // Prepare ancilla in |+⟩ state",
      "    applyGate('H', ancilla);",
      "    ",
      "    // CNOT gates with neighboring data qubits",
      "    neighbors.forEach(qubit => {",
      "      applyGate('CNOT', { control: qubit, target: ancilla });",
      "    });",
      "    ",
      "    // Measure ancilla",
      "    const syndrome = performMeasurement(ancilla);",
      "    ",
      "    // Record syndrome for error correction",
      "    recordSyndrome(ancilla, syndrome);",
      "  }",
      "  ",
      "  // Apply error correction based on syndrome",
      "  applyErrorCorrection(syndrome);",
      "}"
    ],
    "description": "Quantum error correction with surface code"
  },
  "Quantum Benchmark": {
    "prefix": "benchmark",
    "body": [
      "// Quantum circuit benchmark",
      "function benchmarkCircuit(circuit, shots = 1000) {",
      "  const results = [];",
      "  ",
      "  for (let i = 0; i < shots; i++) {",
      "    // Initialize circuit",
      "    const state = initializeState(circuit.qubits);",
      "    ",
      "    // Execute circuit",
      "    circuit.gates.forEach(gate => {",
      "      applyGate(gate.gate, gate.target, gate.options);",
      "    });",
      "    ",
      "    // Measure results",
      "    const measurement = performMeasurement(state);",
      "    results.push(measurement);",
      "  }",
      "  ",
      "  // Calculate statistics",
      "  const stats = calculateStatistics(results);",
      "  const fidelity = calculateFidelity(stats, circuit.expected);",
      "  const coherence = calculateCoherence(results);",
      "  ",
      "  return {",
      "    results,",
      "    statistics: stats,",
      "    fidelity,",
      "    coherence,",
      "    shots",
      "  };",
      "}"
    ],
    "description": "Benchmark quantum circuit performance"
  }
}
