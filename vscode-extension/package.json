{
  "name": "forsure-design-system",
  "displayName": "ForSure Design System",
  "description": "VS Code extension for the ForSure Design System with quantum computing features, IntelliSense, snippets, and development tools",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Snippets",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "forsure",
    "design system",
    "react",
    "typescript",
    "components",
    "ui",
    "accessibility",
    "quantum",
    "quantum computing",
    "superposition",
    "entanglement",
    "quantum circuits"
  ],
  "author": "ForSure Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forsure/design-system"
  },
  "bugs": {
    "url": "https://github.com/forsure/design-system/issues"
  },
  "main": "./out/extension.js",
  "contributes": {
    "snippets": [
      {
        "language": "typescript",
        "path": "./snippets/typescript.json"
      },
      {
        "language": "typescriptreact",
        "path": "./snippets/typescriptreact.json"
      },
      {
        "language": "javascript",
        "path": "./snippets/javascript.json"
      },
      {
        "language": "javascriptreact",
        "path": "./snippets/javascriptreact.json"
      },
      {
        "language": "typescript",
        "path": "./snippets/forsure.json"
      },
      {
        "language": "typescriptreact",
        "path": "./snippets/forsure.json"
      },
      {
        "language": "quantum",
        "path": "./snippets/quantum.json"
      },
      {
        "language": "quantum-circuit",
        "path": "./snippets/quantum.json"
      },
      {
        "language": "quantum-algorithm",
        "path": "./snippets/quantum.json"
      }
    ],
    "commands": [
      {
        "command": "forsure.generateComponent",
        "title": "Generate ForSure Component",
        "category": "ForSure"
      },
      {
        "command": "forsure.generateHook",
        "title": "Generate ForSure Hook",
        "category": "ForSure"
      },
      {
        "command": "forsure.openDocs",
        "title": "Open Documentation",
        "category": "ForSure"
      },
      {
        "command": "forsure.auditDesignSystem",
        "title": "Audit Design System",
        "category": "ForSure"
      },
      {
        "command": "forsure.showTokens",
        "title": "Show Design Tokens",
        "category": "ForSure"
      },
      {
        "command": "forsure.quantum.validateCircuit",
        "title": "Validate Quantum Circuit",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.simulateCircuit",
        "title": "Simulate Quantum Circuit",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.optimizeCircuit",
        "title": "Optimize Quantum Circuit",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.generateSuperposition",
        "title": "Generate Superposition State",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.createEntanglement",
        "title": "Create Entanglement State",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.performMeasurement",
        "title": "Perform Quantum Measurement",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.showQuantumMetrics",
        "title": "Show Quantum Metrics",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.toggleQuantumMode",
        "title": "Toggle Quantum Mode",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.generateDocumentation",
        "title": "Generate Quantum Documentation",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.exportCircuit",
        "title": "Export Quantum Circuit",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.importCircuit",
        "title": "Import Quantum Circuit",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.benchmarkCircuit",
        "title": "Benchmark Quantum Circuit",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.visualizeCircuit",
        "title": "Visualize Quantum Circuit",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.analyzePerformance",
        "title": "Analyze Circuit Performance",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.optimizePerformance",
        "title": "Optimize Circuit Performance",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.runQuantumTests",
        "title": "Run Quantum Tests",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.debugCircuit",
        "title": "Debug Quantum Circuit",
        "category": "ForSure Quantum"
      },
      {
        "command": "forsure.quantum.profileCircuit",
        "title": "Profile Quantum Circuit",
        "category": "ForSure Quantum"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "forsure.generateComponent",
          "group": "forsure",
          "when": "explorerResourceIsFolder"
        }
      ],
      "editor/context": [
        {
          "command": "forsure.generateComponent",
          "group": "forsure",
          "when": "editorLangId == typescript || editorLangId == typescriptreact"
        }
      ]
    },
    "configuration": {
      "title": "ForSure Design System",
      "properties": {
        "forsure.autoImport": {
          "type": "boolean",
          "default": true,
          "description": "Automatically import ForSure components when typing"
        },
        "forsure.componentPrefix": {
          "type": "string",
          "default": "forsure-",
          "description": "Prefix for generated component names"
        },
        "forsure.enableIntelliSense": {
          "type": "boolean",
          "default": true,
          "description": "Enable enhanced IntelliSense for ForSure components"
        },
        "forsure.showAccessibilityHints": {
          "type": "boolean",
          "default": true,
          "description": "Show accessibility hints and warnings"
        },
        "forsure.designTokensPath": {
          "type": "string",
          "default": "./lib/design-tokens.ts",
          "description": "Path to design tokens file"
        },
        "forsure.quantum.enableQuantumMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable quantum computing features"
        },
        "forsure.quantum.enableRealTimeValidation": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time quantum circuit validation"
        },
        "forsure.quantum.enablePerformanceMonitoring": {
          "type": "boolean",
          "default": true,
          "description": "Enable quantum performance monitoring"
        },
        "forsure.quantum.maxSimulationQubits": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 30,
          "description": "Maximum number of qubits for simulation"
        },
        "forsure.quantum.simulationPrecision": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "default": "medium",
          "description": "Simulation precision level"
        },
        "forsure.quantum.showQuantumMetrics": {
          "type": "boolean",
          "default": true,
          "description": "Show quantum metrics in status bar"
        },
        "forsure.quantum.enableExperimentalFeatures": {
          "type": "boolean",
          "default": false,
          "description": "Enable experimental quantum features"
        }
      }
    },
    "languages": [
      {
        "id": "forsure-ds",
        "aliases": ["ForSure DS", "forsure"],
        "extensions": [".forsure"],
        "configuration": "./language-configuration.json"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:quantum",
    "onLanguage:quantum-circuit",
    "onLanguage:quantum-algorithm",
    "onCommand:forsure.generateComponent",
    "onCommand:forsure.generateHook",
    "onCommand:forsure.openDocs",
    "onCommand:forsure.auditDesignSystem",
    "onCommand:forsure.showTokens",
    "onCommand:forsure.quantum.*",
    "workspaceContains:**/*.quantum",
    "workspaceContains:**/*.qcircuit",
    "workspaceContains:**/*.qalgo"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "eslint": "^8.39.0",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.3.0"
  }
}
