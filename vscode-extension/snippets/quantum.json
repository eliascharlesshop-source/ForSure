  "applyGate": {
    "prefix": "gate",
    "body": [
      "applyGate('${1:H}', ${2:0}, {",
      "  phase: ${3:Math.PI/4},",
      "  control: ${4:1},",
      "  target: ${5:0},",
      "  matrix: [",
      "    [${6:1/Math.sqrt(2)}, ${7:1/Math.sqrt(2)}],",
      "    [${8:1/Math.sqrt(2)}, ${9:-1/Math.sqrt(2)}]",
      "  ],",
      "  hermitian: true,",
      "  unitary: true,",
      "  reversible: true,",
      "  controlled: false,",
      "  rotation: false,",
      "  phase: true,",
      "  measurement: {",
      "    basis: 'computational',",
      "    shots: 1000,",
      "    collapse: true,",
      "    uncertainty: 0.01,",
      "    postState: null,",
      "    probability: 0.5,",
      "    result: '|0⟩',",
      "    confidence: 0.95,",
      "    error: 0.01,",
      "    timestamp: Date.now(),",
      "    metadata: {",
      "      algorithm: 'gate',",
      "      depth: 1,",
      "      width: 1,",
      "      gates: 1,",
      "      measurements: 0,",
      "      optimizations: [],",
      "      errors: [],",
      "      warnings: [],",
      "      suggestions: [],",
      "    }",
      "  }",
      "})$0"
    ],
    "description": "Apply a quantum gate to a qubit"
  },
  "performMeasurement": {
