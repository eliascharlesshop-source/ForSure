      "    { gate: 'RY', target: 0, phase: 1.230959417 }, // arccos(1/√3)",
      "    { gate: 'CNOT', control: 0, target: 1 },",
      "    { gate: 'CNOT', control: 0, target: 2 },",
      "    { gate: 'X', target: 0 },",
