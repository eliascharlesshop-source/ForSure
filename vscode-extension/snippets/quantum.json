{
  "quantumCircuit": {
    "prefix": "qcircuit",
    "body": [
      "quantumCircuit({",
      "  name: '${1:bell-state}',",
      "  qubits: ${2:2},",
      "  gates: [",
      "    { gate: 'H', target: 0 },",
      "    { gate: 'CNOT', control: 0, target: 1 }",
      "  ],",
      "  measurements: [",
      "    { qubit: 0, basis: 'computational' },",
      "    { qubit: 1, basis: 'computational' }",
      "  ]",
      "})$0"
    ],
    "description": "Create a quantum circuit with gates and measurements"
  },
  "quantumState": {
    "prefix": "qstate",
    "body": [
      "createQuantumState(${1:numQubits}, {",
      "  initialState: '${2:|0⟩}',",
      "  amplitude: ${3:1.0},",
      "  phase: ${4:0.0}",
      "  normalization: true",
