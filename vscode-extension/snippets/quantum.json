      "      warnings: [],",
      "      suggestions: [],",
      "    }",
      "  }",
      "})$0"
    ],
    "description": "Create a superposition quantum state"
  },
  "entanglementState": {
    "prefix": "entanglement",
    "body": [
      "createEntanglement([${1:0}, ${2:1}], {",
      "  bellState: '${3:Φ+}',",
      "  maximallyEntangled: true,",
      "  fidelity: 0.99,",
