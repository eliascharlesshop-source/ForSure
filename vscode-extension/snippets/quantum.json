  "optimizeCircuit": {
    "prefix": "optimize",
    "body": [
      "optimizeCircuit(${1:circuit}, {",
      "  rules: ['gate-fusion', 'gate-cancellation', 'gate-reordering', 'template-matching'],",
      "  target: 'depth',",
      "  maxIterations: 100,",
      "  tolerance: 0.001,",
      "  preserveSemantics: true,",
      "  measurement: {",
      "    basis: 'computational',",
