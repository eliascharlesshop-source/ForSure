      "  '${1:|00⟩}', '${2:|01⟩}', '${3:|10⟩}', '${4:|11⟩}'",
      "], {",
      "  amplitudes: [${5:0.5}, ${6:0.5}, ${7:0.5}, ${8:0.5}],",
      "  phases: [${9:0}, ${10:0}, ${11:0}, ${12:0}],",
      "  normalization: 1.0,",
      "  coherence: 0.98,",
      "  entanglement: false,",
      "  fidelity: 0.99,",
      "  purity: 1.0,",
      "  vonNeumannEntropy: 1.0,",
      "  measurement: {",
