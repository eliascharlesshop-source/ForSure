  "bellState": {
    "prefix": "bell",
    "body": [
      "// Bell State |Φ+⟩",
      "quantumCircuit({",
      "  name: 'bell-state-phi-plus',",
      "  qubits: 2,",
      "  gates: [",
      "    { gate: 'H', target: 0 },",
      "    { gate: 'CNOT', control: 0, target: 1 }",
      "  ],",
      "  measurements: [",
      "    { qubit: 0, basis: 'computational' },",
      "    { qubit: 1, basis: 'computational' }",
      "  ]",
      "})$0"
    ],
    "description": "Create a Bell state circuit"
  },
  "ghzState": {
    "prefix": "ghz",
    "body": [
      "// GHZ State",
      "quantumCircuit({",
      "  name: 'ghz-state',",
      "  qubits: 3,",
      "  gates: [",
      "    { gate: 'H', target: 0 },",
      "    { gate: 'CNOT', control: 0, target: 1 },",
      "    { gate: 'CNOT', control: 0, target: 2 }",
      "  ],",
      "  measurements: [",
      "    { qubit: 0, basis: 'computational' },",
      "    { qubit: 1, basis: 'computational' },",
      "    { qubit: 2, basis: 'computational' }",
      "  ]",
      "})$0"
    ],
    "description": "Create a GHZ state circuit"
  },
  "groverAlgorithm": {
    "prefix": "grover",
    "body": [
      "// Grover's Algorithm",
      "quantumCircuit({",
      "  name: 'grover-algorithm',",
      "  qubits: ${1:3},",
      "  gates: [",
      "    // Initialize superposition",
      "    ...Array(${2:3}).fill(0).map((_, i) => ({ gate: 'H', target: i })),",
      "    ",
      "    // Oracle",
      "    { gate: 'Z', target: ${3:2} },",
      "    ",
      "    // Diffusion operator",
      "    ...Array(${4:3}).fill(0).map((_, i) => ({ gate: 'H', target: i })),",
      "    { gate: 'Z', target: 0 },",
      "    ...Array(${5:3}).fill(0).map((_, i) => ({ gate: 'H', target: i }))",
      "  ],",
      "  measurements: [",
      "    ...Array(${6:3}).fill(0).map((_, i) => ({ qubit: i, basis: 'computational' }))",
      "  ]",
      "})$0"
    ],
    "description": "Implement Grover's search algorithm"
  },
  "quantumFourierTransform": {
    "prefix": "qft",
    "body": [
      "// Quantum Fourier Transform",
      "quantumCircuit({",
      "  name: 'quantum-fourier-transform',",
      "  qubits: ${1:3},",
      "  gates: [",
      "    // Apply H to first qubit",
      "    { gate: 'H', target: 0 },",
      "    ",
      "    // Apply controlled rotations",
      "    ...Array(${2:2}).fill(0).map((_, i) => ({",
      "      gate: 'CRZ',",
      "      control: i + 1,",
      "      target: 0,",
      "      phase: Math.PI / Math.pow(2, i + 1)",
      "    })),",
      "    ",
      "    // Apply H to remaining qubits",
      "    ...Array(${3:2}).fill(0).map((_, i) => ({ gate: 'H', target: i + 1 }))",
      "  ],",
      "  measurements: [",
      "    ...Array(${4:3}).fill(0).map((_, i) => ({ qubit: i, basis: 'computational' }))",
      "  ]",
      "})$0"
    ],
    "description": "Implement Quantum Fourier Transform"
  },
  "teleportationProtocol": {
    "prefix": "teleport",
    "body": [
      "// Quantum Teleportation Protocol",
      "quantumCircuit({",
      "  name: 'quantum-teleportation',",
      "  qubits: 3,",
      "  gates: [",
      "    // Create Bell state between qubits 1 and 2",
      "    { gate: 'H', target: 1 },",
      "    { gate: 'CNOT', control: 1, target: 2 },",
      "    ",
      "    // Bell measurement on qubits 0 and 1",
      "    { gate: 'CNOT', control: 0, target: 1 },",
      "    { gate: 'H', target: 0 },",
      "    ",
      "    // Conditional operations on qubit 2",
      "    { gate: 'CNOT', control: 1, target: 2 },",
      "    { gate: 'CZ', control: 0, target: 2 }",
      "  ],",
      "  measurements: [",
      "    { qubit: 0, basis: 'computational' },",
      "    { qubit: 1, basis: 'computational' },",
      "    { qubit: 2, basis: 'computational' }",
      "  ]",
      "})$0"
    ],
    "description": "Implement quantum teleportation protocol"
  },
  "quantumErrorCorrection": {
    "prefix": "qec",
    "body": [
      "// Quantum Error Correction (3-qubit bit flip code)",
      "quantumCircuit({",
      "  name: 'quantum-error-correction',",
      "  qubits: 3,",
      "  gates: [",
      "    // Encode logical qubit",
      "    { gate: 'CNOT', control: 0, target: 1 },",
      "    { gate: 'CNOT', control: 0, target: 2 },",
      "    ",
      "    // Error correction",
      "    { gate: 'CNOT', control: 0, target: 1 },",
      "    { gate: 'CNOT', control: 0, target: 2 },",
      "    { gate: 'CCX', control: [1, 2], target: 0 },",
      "    ",
      "    // Decode",
      "    { gate: 'CNOT', control: 0, target: 1 },",
      "    { gate: 'CNOT', control: 0, target: 2 }",
      "  ],",
      "  measurements: [",
      "    { qubit: 0, basis: 'computational' },",
      "    { qubit: 1, basis: 'computational' },",
      "    { qubit: 2, basis: 'computational' }",
      "  ]",
      "})$0"
    ],
    "description": "Implement quantum error correction code"
  },
  "denseCoding": {
    "prefix": "dense",
    "body": [
      "// Dense Coding Protocol",
      "quantumCircuit({",
      "  name: 'dense-coding',",
      "  qubits: 2,",
      "  gates: [",
      "    // Create Bell state",
      "    { gate: 'H', target: 0 },",
      "    { gate: 'CNOT', control: 0, target: 1 },",
      "    ",
      "    // Encode 2 classical bits (example: 11)",
      "    { gate: 'Z', target: 0 },",
      "    { gate: 'X', target: 0 },",
      "    ",
      "    // Decode",
      "    { gate: 'CNOT', control: 0, target: 1 },",
      "    { gate: 'H', target: 0 }",
      "  ],",
      "  measurements: [",
      "    { qubit: 0, basis: 'computational' },",
      "    { qubit: 1, basis: 'computational' }",
      "  ]",
      "})$0"
    ],
    "description": "Implement dense coding protocol"
  },
  "wState": {
