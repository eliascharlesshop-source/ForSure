      "  coherence: 0.98",
      "  entanglement: false",
      "  superposition: false",
      "  measurement: {",
      "    basis: 'computational',",
      "    shots: 1000,",
      "    collapse: true",
      "    uncertainty: 0.01",
      "    postState: null",
      "    probability: 0.5",
      "    result: '|0⟩'",
      "    confidence: 0.95",
      "    error: 0.01",
