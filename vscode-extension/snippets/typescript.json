  "ForSure Component Template": {
    "prefix": ["fcomponent", "fs-component"],
    "body": [
      "import * as React from 'react'",
      "import { cva, type VariantProps } from 'class-variance-authority'",
      "import { cn } from '@/lib/utils'",
      "import { ForSureComponentProps } from '@/lib/ui-types'",
      "",
      "const ${1:componentName}Variants = cva(",
      "  '',",
      "  {",
      "    variants: {",
      "      variant: {",
      "        default: '',",
      "        secondary: '',",
      "        destructive: '',",
      "        outline: '',",
      "        ghost: '',",
      "        link: '',",
      "      },",
      "      size: {",
      "        sm: '',",
      "        md: '',",
      "        lg: '',",
      "        xl: '',",
      "      },",
      "    },",
      "    defaultVariants: {",
      "      variant: 'default',",
      "      size: 'md',",
      "    },",
      "  }",
      ")",
      "",
      "export interface ${2:ComponentName}Props",
      "  extends React.HTMLAttributes<HTMLDivElement>,",
      "    VariantProps<typeof ${1:componentName}Variants>,",
      "    Omit<ForSureComponentProps<HTMLDivElement>, 'size'> {",
      "  asChild?: boolean",
      "}",
      "",
      "const ${2:ComponentName} = React.forwardRef<HTMLDivElement, ${2:ComponentName}Props>(",
      "  ({ className, variant, size, asChild = false, ...props }, ref) => {",
      "    if (asChild) {",
      "      return <>{props.children}</>",
      "    }",
      "    ",
      "    return (",
      "      <div",
      "        className={cn(${1:componentName}Variants({ variant, size }), className)}",
      "        ref={ref}",
      "        {...props}",
      "      />",
      "    )",
      "  }",
      ")",
      "${2:ComponentName}.displayName = '${2:ComponentName}'",
      "",
      "export { ${2:ComponentName}, ${1:componentName}Variants }"
    ],
    "description": "ForSure component template with variants and TypeScript"
  },
  "ForSure Hook Template": {
    "prefix": ["fhook", "fs-hook"],
    "body": [
      "import { useState, useEffect, useCallback } from 'react'",
      "",
      "export interface Use${1:HookName}Options {",
      "  // Add options here",
      "}",
      "",
      "export interface Use${1:HookName}Return {",
      "  // Add return values here",
      "}",
      "",
      "export function use${1:HookName}(options: Use${1:HookName}Options = {}): Use${1:HookName}Return {",
      "  const [state, setState] = useState(null)",
      "",
      "  const handler = useCallback(() => {",
      "    // Add logic here",
      "  }, [])",
      "",
      "  useEffect(() => {",
      "    // Add effects here",
      "  }, [])",
      "",
      "  return {",
      "    // Return values here",
      "  }",
      "}"
    ],
    "description": "ForSure hook template with TypeScript"
  },
  "ForSure Form Component": {
    "prefix": ["fform", "fs-form"],
    "body": [
      "import * as React from 'react'",
      "import { cva, type VariantProps } from 'class-variance-authority'",
      "import { cn } from '@/lib/utils'",
      "import { ForSureComponentProps } from '@/lib/ui-types'",
      "",
      "const ${1:componentName}Variants = cva(",
      "  '',",
      "  {",
      "    variants: {",
      "      variant: {",
      "        default: '',",
      "        error: '',",
      "        success: '',",
      "      },",
      "      size: {",
      "        sm: '',",
      "        md: '',",
      "        lg: '',",
      "      },",
      "    },",
      "    defaultVariants: {",
      "      variant: 'default',",
      "      size: 'md',",
      "    },",
      "  }",
      ")",
      "",
      "export interface ${2:ComponentName}Props",
      "  extends React.InputHTMLAttributes<HTMLInputElement>,",
      "    VariantProps<typeof ${1:componentName}Variants>,",
      "    Omit<ForSureComponentProps<HTMLInputElement>, 'size'> {",
      "  label?: string",
      "  error?: string",
      "  helperText?: string",
      "  required?: boolean",
      "}",
      "",
      "const ${2:ComponentName} = React.forwardRef<HTMLInputElement, ${2:ComponentName}Props>(",
      "  ({ className, variant, size, label, error, helperText, required, id, ...props }, ref) => {",
      "    const inputId = id || \\`\\${${1:componentName}}-\\${React.useId()}\\`",
      "    ",
      "    return (",
      "      <div className=\"space-y-2\">",
      "        {label && (",
      "          <label",
      "            htmlFor={inputId}",
      "            className=\"text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-70\"",
      "          >",
      "            {label}",
      "            {required && <span className=\"text-destructive ml-1\">*</span>}",
      "          </label>",
      "        )}",
      "        <input",
      "          className={cn(${1:componentName}Variants({ variant, size }), className)}",
      "          ref={ref}",
      "          id={inputId}",
      "          aria-invalid={error ? 'true' : 'false'}",
      "          aria-describedby={error ? \\`\\${inputId}-error\\` : helperText ? \\`\\${inputId}-helper\\` : undefined}",
      "          {...props}",
      "        />",
      "        {error && (",
      "          <p id={\\`\\${inputId}-error\\`} className=\"text-sm text-destructive\">",
      "            {error}",
      "          </p>",
      "        )}",
      "        {helperText && !error && (",
      "          <p id={\\`\\${inputId}-helper\\`} className=\"text-sm text-muted-foreground\">",
      "            {helperText}",
      "          </p>",
      "        )}",
      "      </div>",
      "    )",
      "  }",
      ")",
      "${2:ComponentName}.displayName = '${2:ComponentName}'",
      "",
      "export { ${2:ComponentName}, ${1:componentName}Variants }"
    ],
    "description": "ForSure form component template with validation"
  },
  "ForSure Accessibility Component": {
    "prefix": ["fa11y", "fs-a11y"],
    "body": [
      "import { SkipLink, Landmark, Heading, Link, FocusIndicator, LiveRegion } from '@/components/ui/accessibility';",
      "",
      "<SkipLink href=\"#main-content\">Skip to main content</SkipLink>",
      "",
      "<Landmark as=\"main\" id=\"main-content\">",
      "  <Heading level=\"1\">Page Title</Heading>",
      "  <FocusIndicator>",
      "    <Link href=\"#\">Accessible Link</Link>",
      "  </FocusIndicator>",
      "</Landmark>",
      "",
      "<LiveRegion politeness=\"polite\">",
      "  {/* Dynamic content announcements */}",
      "</LiveRegion>"
    ],
    "description": "ForSure accessibility components template"
  }
}
