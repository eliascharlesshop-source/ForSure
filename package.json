{
  "name": "forsure-cli",
  "version": "0.1.0",
  "bin": "./cli-bin-forsure",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "seed:prisma": "dotenv -e .env.local -- tsx scripts/seed.prisma.ts",
    "seed:prod": "tsx scripts/seed-production.ts",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "prisma:pull": "dotenv -e .env.local -- prisma db pull",
    "prisma:push": "dotenv -e .env.local -- prisma db push",
    "prisma:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:studio": "dotenv -e .env.local -- prisma studio",
    "db:pull": "pnpm prisma:pull",
    "db:push": "pnpm prisma:push",
    "db:migrate": "pnpm prisma:migrate",
    "db:migrate:prod": "./scripts/migrate.sh",
    "db:health": "tsx scripts/db-health-check.ts",
    "db:health:json": "tsx scripts/db-health-check.ts --json",
    "db:backup": "pg_dump $DIRECT_URL > backup_$(date +%Y%m%d_%H%M%S).sql",
    "db:backup:prod": "./scripts/backup-db.sh",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "postinstall": "husky install"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "latest",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.15.0",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "2.2.4",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "1.1.4",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@supabase/supabase-js": "^2.50.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.2",
    "blessed": "^0.1.81",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "commander": "^12.0.0",
    "date-fns": "latest",
    "embla-carousel-react": "8.5.1",
    "framer-motion": "latest",
    "graphql": "^16.11.0",
    "graphql-yoga": "^5.15.1",
    "gsap": "latest",
    "input-otp": "1.4.1",
    "inquirer": "^13.3.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.454.0",
    "next": "15.2.4",
    "next-themes": "latest",
    "pg": "^8.13.1",
    "react": "^19",
    "react-day-picker": "9.14.0",
    "react-dom": "^19",
    "react-hook-form": "^7.54.1",
    "react-resizable-panels": "^2.1.7",
    "react-syntax-highlighter": "latest",
    "recharts": "2.15.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.34",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.5.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "prisma": "^6.15.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
