    const response = await axios.post('https://api.forsure-neural.ai/initialize', {
      projectName: options.name,
      features: options.neuralFeatures || [],
      template: options.template,
      deployment: options.deployment,
      neural: options.neural || false,
      emotional: options.emotional || false,
      adaptive: options.adaptive || false
    }, {
      timeout: 10000,
      headers: {
        'Authorization': `Bearer ${process.env.FORSURE_NEURAL_AI_TOKEN || 'demo-token'}`
      }
