      console.log(`Components: ${auditResults.components}`)
      console.log(`Tokens used: ${auditResults.tokensUsed}`)
      console.log(`Issues found: ${auditResults.issues.length}`)
      
      if (auditResults.issues.length > 0) {
        console.log(chalk.yellow('\n⚠️ Issues:'))
        auditResults.issues.forEach(issue => {
          console.log(`  - ${issue}`)
        })
        
        if (options.fix) {
          log.info('Attempting to fix issues...')
          await fixAuditIssues(auditResults.issues)
        }
      }
      
      if (options.report) {
        await generateAuditReport(auditResults)
        log.success('Detailed report generated: design-system-audit.json')
      }
    } catch (error) {
      log.error(`Audit failed: ${error.message}`)
    }
  })

// Helper functions
function getTemplateChoices(type) {
  const templates = {
    component: [
      { name: 'Basic Component', value: 'basic' },
      { name: 'Form Component', value: 'form' },
      { name: 'Layout Component', value: 'layout' },
      { name: 'Data Display Component', value: 'data' },
    ],
    hook: [
      { name: 'Basic Hook', value: 'basic' },
      { name: 'API Hook', value: 'api' },
      { name: 'Form Hook', value: 'form' },
      { name: 'Storage Hook', value: 'storage' },
    ],
    utility: [
      { name: 'Basic Utility', value: 'basic' },
      { name: 'Validation Utility', value: 'validation' },
      { name: 'Format Utility', value: 'format' },
      { name: 'DOM Utility', value: 'dom' },
    ],
  }
  return templates[type] || [{ name: 'Basic', value: 'basic' }]
}

function getDefaultDirectory(type) {
  const directories = {
    component: 'components/ui',
    hook: 'hooks',
    utility: 'lib/utils',
    page: 'app/pages',
    layout: 'app/layouts',
    service: 'lib/services',
    type: 'lib/types',
  }
  return directories[type] || '.'
}

async function generateCode(type, options) {
  const templates = {
    component: getComponentTemplate(options.name, options.template),
    hook: getHookTemplate(options.name, options.template),
    utility: getUtilityTemplate(options.name, options.template),
    page: getPageTemplate(options.name),
    layout: getLayoutTemplate(options.name),
    service: getServiceTemplate(options.name),
    type: getTypeTemplate(options.name),
  }

  const componentDir = path.join(process.cwd(), options.dir)
  if (!fs.existsSync(componentDir)) {
    fs.mkdirSync(componentDir, { recursive: true })
    log.success(`Created directory: ${componentDir}`)
  }

  const fileName = type === 'type' ? `${options.name}.ts` : `forsure-${options.name}.tsx`
  const filePath = path.join(componentDir, fileName)

  if (fs.existsSync(filePath)) {
    throw new Error(`File already exists: ${filePath}`)
  }

  fs.writeFileSync(filePath, templates[type])

  // Generate additional files
  if (options.storybook && type === 'component') {
    const storyPath = path.join(componentDir, `${options.name}.stories.tsx`)
    fs.writeFileSync(storyPath, getStorybookTemplate(options.name))
  }

  if (options.test) {
    const testDir = path.join(process.cwd(), '__tests__', type === 'component' ? 'components' : type === 'hook' ? 'hooks' : 'utils')
    if (!fs.existsSync(testDir)) {
      fs.mkdirSync(testDir, { recursive: true })
    }
    const testPath = path.join(testDir, `${options.name}.test.${type === 'type' ? 'ts' : 'tsx'}`)
    fs.writeFileSync(testPath, getTestTemplate(options.name, type))
  }

  if (options.typescript && type !== 'type') {
    const typesPath = path.join(componentDir, `${options.name}.types.ts`)
    fs.writeFileSync(typesPath, getTypesTemplate(options.name, type))
  }
}

