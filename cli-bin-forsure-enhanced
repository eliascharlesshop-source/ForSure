}

const runScript = async (scriptName, args = []) => {
  return new Promise((resolve, reject) => {
    const spinner = ora(`Running ${scriptName}...`).start()
    const child = spawn('npm', ['run', scriptName, ...args], {
      stdio: 'pipe',
      cwd: process.cwd(),
    })

    let output = ''
    let errorOutput = ''

    child.stdout.on('data', (data) => {
      output += data.toString()
    })

    child.stderr.on('data', (data) => {
      errorOutput += data.toString()
    })

    child.on('close', (code) => {
      if (code === 0) {
        spinner.succeed(`${scriptName} completed`)
        resolve({ output, code })
      } else {
        spinner.fail(`${scriptName} failed`)
        reject(new Error(errorOutput || `Script exited with code ${code}`))
      }
    })

    child.on('error', (error) => {
      spinner.fail(`Failed to run ${scriptName}`)
      reject(error)
    })
  })
}

// Enhanced component generation
program
  .command('generate <type>')
  .alias('gen')
  .description('Generate components, hooks, utilities, and more with interactive prompts')
  .option('-n, --name <name>', 'Component/hook/utility name')
  .option('-d, --dir <directory>', 'Target directory')
  .option('-t, --template <template>', 'Template to use')
  .option('--storybook', 'Generate Storybook stories')
  .option('--test', 'Generate test files')
  .option('--typescript', 'Generate TypeScript definitions')
  .action(async (type, options) => {
    try {
      console.log(chalk.cyan(figlet.textSync('ForSure CLI', { font: 'Small' })))
      console.log(chalk.gray('Design System Development Tools\n'))

      const availableTypes = ['component', 'hook', 'utility', 'page', 'layout', 'service', 'type']
      if (!availableTypes.includes(type)) {
        log.error(`Invalid type "${type}". Available types: ${availableTypes.join(', ')}`)
        return
      }

      // Interactive prompts for missing options
      if (!options.name) {
        const answers = await inquirer.prompt([
          {
            type: 'input',
            name: 'name',
            message: `Enter ${type} name:`,
            validate: (input) => {
              if (!input.trim()) return 'Name is required'
              if (!/^[a-zA-Z][a-zA-Z0-9-_]*$/.test(input)) {
                return 'Name must start with a letter and contain only letters, numbers, hyphens, and underscores'
              }
              return true
            },
            filter: (input) => input.toLowerCase().trim(),
          },
          {
            type: 'list',
            name: 'template',
            message: 'Choose template:',
            choices: getTemplateChoices(type),
            when: () => !options.template,
          },
          {
            type: 'input',
            name: 'dir',
            message: 'Target directory:',
            default: getDefaultDirectory(type),
            when: () => !options.dir,
          },
          {
            type: 'confirm',
            name: 'storybook',
            message: 'Generate Storybook story?',
            default: type === 'component',
            when: () => !options.storybook && type === 'component',
          },
          {
            type: 'confirm',
            name: 'test',
            message: 'Generate test file?',
            default: true,
            when: () => !options.test,
          },
          {
            type: 'confirm',
            name: 'typescript',
            message: 'Generate TypeScript definitions?',
            default: true,
            when: () => !options.typescript,
          },
        ])

        Object.assign(options, answers)
      }

      await generateCode(type, options)
      log.success(`Generated ${type} "${options.name}" successfully!`)
      
      if (options.storybook && type === 'component') {
        log.info('Don\'t forget to run: npm run storybook')
      }
    } catch (error) {
      log.error(`Failed to generate ${type}: ${error.message}`)
    }
  })

// Design system management
program
  .command('design')
  .description('Design system management commands')
  .command('tokens')
  .description('Generate CSS variables and theme files from design tokens')
  .option('--format <format>', 'Output format (css, scss, json)', 'css')
  .option('--watch', 'Watch for changes and regenerate')
  .action(async (options) => {
    try {
      const spinner = ora('Processing design tokens...').start()
      
      const tokensPath = path.join(process.cwd(), 'lib/design-tokens.ts')
      const outputPath = path.join(process.cwd(), `styles/design-tokens.${options.format}`)
      
      if (!fs.existsSync(tokensPath)) {
        spinner.fail('Design tokens file not found')
        log.error('Expected: lib/design-tokens.ts')
        return
      }

      await generateDesignTokens(tokensPath, outputPath, options.format)
      spinner.succeed(`Generated design tokens in ${options.format} format`)
      
      if (options.watch) {
        log.info('Watching for changes...')
        fs.watchFile(tokensPath, async () => {
          const watchSpinner = ora('Regenerating tokens...').start()
          await generateDesignTokens(tokensPath, outputPath, options.format)
          watchSpinner.succeed('Tokens regenerated')
        })
      }
    } catch (error) {
      log.error(`Failed to generate tokens: ${error.message}`)
    }
  })

