async function installCognitiveDependencies(projectPath, packageManager) {
  return new Promise((resolve, reject) => {
    const installCmd = packageManager === 'npm' ? 'install' : 
                       packageManager === 'yarn' ? 'add' :
                       packageManager === 'pnpm' ? 'add' :
                       packageManager === 'bun' ? 'install' :
                       packageManager === 'cognitive-pm' ? 'cognitive-install' : 'install'
    
    const child = spawn(packageManager, [installCmd], {
      cwd: projectPath,
      stdio: 'inherit',
    })
    
    child.on('close', (code) => {
      if (code === 0) {
        resolve()
      } else {
        reject(new Error(`${packageManager} ${installCmd} failed with code ${code}`))
      }
    })
  })
}

async function initializeCognitiveGit(projectPath, options) {
  const gitCommands = [
    'git init',
    'git add .',
    'git commit -m "Initial cognitive commit"',
  ]

  if (options.blockchain) {
    gitCommands.push('git branch -M main')
    gitCommands.push('git remote add origin https://github.com/forsure/cognitive-blockchain.git')
    gitCommands.push('git push -u origin main')
  }

  for (const cmd of gitCommands) {
    await new Promise((resolve, reject) => {
      const child = spawn(cmd, { shell: true, cwd: projectPath, stdio: 'inherit' })
      child.on('close', (code) => {
        if (code === 0) resolve()
        else reject(new Error(`${cmd} failed with code ${code}`))
      })
    })
  }
}

