// Advanced helper functions
async function scaffoldProject(options) {
  const spinner = ora('Scaffolding project...').start()
  
  try {
    // Create project directory
    const projectPath = path.resolve(process.cwd(), options.directory)
    if (!fs.existsSync(projectPath)) {
      fs.mkdirSync(projectPath, { recursive: true })
    }

    // Copy template files
    const templatePath = path.join(__dirname, '../templates', options.template)
    if (fs.existsSync(templatePath)) {
      await copyTemplate(templatePath, projectPath, options)
    } else {
      await createProjectFromScratch(projectPath, options)
    }

    // Initialize package.json
    await createPackageJson(projectPath, options)
    
    // Setup configuration files
    if (options.typescript) await setupTypeScript(projectPath)
    if (options.tailwind) await setupTailwind(projectPath)
    if (options.storybook) await setupStorybook(projectPath)
    if (options.testing) await setupTesting(projectPath)
    
    // Install dependencies
    spinner.text = 'Installing dependencies...'
    await installDependencies(projectPath)
    
    // Initialize git
    await initializeGit(projectPath)
    
    spinner.succeed('Project scaffolded successfully!')
  } catch (error) {
    spinner.fail('Scaffolding failed')
    throw error
  }
}

async function migrateProject(options) {
  const spinner = ora('Analyzing project...').start()
  
  try {
    // Analyze current project structure
    const projectAnalysis = await analyzeCurrentProject()
    
    // Create migration plan
    const migrationPlan = await createMigrationPlan(projectAnalysis, options.from)
    
    if (options.dryRun) {
      spinner.succeed('Dry run completed')
      log.info('Migration plan:')
      migrationPlan.steps.forEach(step => {
        log.info(`  - ${step.description}`)
      })
      return
    }
    
    // Create backup if requested
    if (options.backup) {
      await createBackup()
    }
    
    // Execute migration
    spinner.text = 'Migrating components...'
    await executeMigration(migrationPlan)
    
    spinner.succeed('Migration completed!')
  } catch (error) {
    spinner.fail('Migration failed')
    throw error
  }
}

async function checkForUpdates() {
  const spinner = ora('Checking for updates...').start()
  
  try {
    const currentVersion = getCurrentVersion()
    const latestVersion = await getLatestVersion()
    
    if (semver.gt(latestVersion, currentVersion)) {
      spinner.succeed('Update available!')
      log.info(`Current: ${currentVersion}`)
      log.info(`Latest: ${latestVersion}`)
      log.info(`Run 'forsure upgrade --version ${latestVersion}' to update`)
    } else {
      spinner.succeed('Up to date!')
      log.info(`Current version: ${currentVersion}`)
    }
  } catch (error) {
    spinner.fail('Update check failed')
    throw error
  }
}

async function upgradeDesignSystem(options) {
  const spinner = ora('Upgrading design system...').start()
  
  try {
    const targetVersion = options.version || await getLatestVersion()
    
    // Check for breaking changes
    const breakingChanges = await checkBreakingChanges(targetVersion)
    if (breakingChanges.length > 0 && !options.force) {
      spinner.fail('Breaking changes detected')
      log.warning('Breaking changes:')
      breakingChanges.forEach(change => {
        log.warning(`  - ${change.description}`)
      })
      log.info('Use --force to proceed anyway')
      return
    }
    
    // Run tests before upgrade
    spinner.text = 'Running tests...'
    await runTests()
    
    // Update dependencies
    spinner.text = 'Updating dependencies...'
    await updateDependencies(targetVersion)
    
    // Run migration scripts
    spinner.text = 'Running migration scripts...'
    await runMigrationScripts(targetVersion)
    
    // Verify upgrade
    spinner.text = 'Verifying upgrade...'
    await verifyUpgrade()
    
    spinner.succeed('Upgrade completed!')
  } catch (error) {
    spinner.fail('Upgrade failed')
    throw error
  }
}

async function publishLibrary(options) {
  const spinner = ora('Publishing library...').start()
  
  try {
    // Validate package
    spinner.text = 'Validating package...'
    await validatePackage()
    
    // Run tests
    if (!options.skipTests) {
      spinner.text = 'Running tests...'
      await runTests()
    }
    
    // Build package
    if (!options.skipBuild) {
      spinner.text = 'Building package...'
      await buildPackage()
    }
    
    // Check if version already exists
    const currentVersion = getCurrentVersion()
    const publishedVersions = await getPublishedVersions()
    if (publishedVersions.includes(currentVersion) && !options.dryRun) {
      spinner.fail('Version already published')
      log.error(`Version ${currentVersion} already exists on npm`)
      return
    }
    
    // Publish to npm
    if (!options.dryRun) {
      spinner.text = 'Publishing to npm...'
      await publishToNpm(options.tag)
    }
    
    // Create GitHub release
    if (!options.dryRun) {
      spinner.text = 'Creating GitHub release...'
      await createGitHubRelease(currentVersion)
    }
    
    spinner.succeed(options.dryRun ? 'Dry run completed!' : 'Library published successfully!')
  } catch (error) {
    spinner.fail('Publishing failed')
    throw error
  }
}

